{
    "version": "99.0",
    "description": "A set of tools to create, alter and inspect Matroska files",
    "homepage": "https://mkvtoolnix.download",
    "license": "GPL-2.0-only",
    "architecture": {
        "64bit": {
            "url": "https://mkvtoolnix.download/windows/releases/99.0/mkvtoolnix-64-bit-99.0.7z",
            "hash": "sha512:753581522b7bac2ed629f4b06b0935ee71fb3c10ce09a76078fe7516efc58ebf3ef4ff30af78190db2be975a8944346a11ddc9292b6bd9e90f3202c3e5a5d654"
        }
    },
    "extract_dir": "mkvtoolnix",
    "post_install": [
        "Remove-Item $dir\\data\\portable-app, $dir\\locale -Recurse",
        "Get-ChildItem $dir\\doc -Exclude licenses | Remove-Item -Recurse"
    ],
    "bin": [
        "mkvextract.exe",
        "mkvinfo.exe",
        "mkvmerge.exe",
        "mkvpropedit.exe",
        "mkvtoolnix-gui.exe"
    ],
    "shortcuts": [
        [
            "mkvtoolnix-gui.exe",
            "MKVToolNix GUI"
        ]
    ],
    "checkver": {
        "url": "https://mkvtoolnix.download/doc/NEWS.md",
        "regex": "([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://mkvtoolnix.download/windows/releases/$version/mkvtoolnix-64-bit-$version.7z"
            }
        },
        "hash": {
            "url": "$baseurl/sha512sums.txt"
        }
    }
}
